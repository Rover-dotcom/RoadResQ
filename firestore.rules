rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────────
    function isSignedIn()       { return request.auth != null; }
    function isAdmin()          { return isSignedIn() && request.auth.token.role == 'admin'; }
    function isOwner(uid)       { return isSignedIn() && request.auth.uid == uid; }
    function isDriverRole()     { return isSignedIn() && request.auth.token.role == 'driver'; }
    function isGarageRole()     { return isSignedIn() && request.auth.token.role == 'garage'; }

    // ─── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Jobs ─────────────────────────────────────────────────────────────────
    match /jobs/{jobId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Drivers ──────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin() || (isDriverRole() && isOwner(driverId));
      allow update: if isAdmin() || isOwner(driverId);
      allow delete: if isAdmin();
    }

    // ─── Quotes ───────────────────────────────────────────────────────────────
    match /quotes/{quoteId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Garage Requests ──────────────────────────────────────────────────────
    match /garage_requests/{reqId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Incidents (Admin Safety Dashboard) ───────────────────────────────────
    match /incidents/{incId} {
      allow read:   if isAdmin() || isSignedIn();
      allow create: if isSignedIn();               // any signed-in user can report
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Disputes (ADR) ───────────────────────────────────────────────────────
    match /disputes/{dispId} {
      allow read:   if isSignedIn();               // users can see own disputes
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Fraud Flags ──────────────────────────────────────────────────────────
    match /fraud_flags/{flagId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ─── Admin Alerts ─────────────────────────────────────────────────────────
    match /admin_alerts/{alertId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin() || isSignedIn();  // system writes, admin reads/updates
    }

    // ─── Safety Confirmations ─────────────────────────────────────────────────
    match /safety_confirmations/{confId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Safety Feedback ──────────────────────────────────────────────────────
    match /safety_feedback/{fbId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Discipline Logs ──────────────────────────────────────────────────────
    match /discipline_logs/{logId} {
      allow read:   if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Compliance Alerts ────────────────────────────────────────────────────
    match /compliance_alerts/{alertId} {
      allow read:   if isAdmin() || isDriverRole();
      allow write:  if isAdmin();
    }

    // ─── Schema Reference (read-only) ─────────────────────────────────────────
    match /_schema/{doc} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }

    // ─── Week 5: Safety Checklists ────────────────────────────────────────────
    match /safety_checklists/{checkId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Week 5: Payments ─────────────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read:   if isSignedIn();               // users can read own payment status
      allow create: if isSignedIn();               // system creates via admin SDK
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Week 5: Reports ──────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read:   if isSignedIn();               // users can read own job reports
      allow create: if isSignedIn();               // system creates via admin SDK
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Week 5: Audit Logs ───────────────────────────────────────────────────
    match /audit_logs/{logId} {
      allow read:   if isAdmin();                  // admin only
      allow write:  if isAdmin();                  // system writes via admin SDK
    }

    // ─── Week 5: Pending Deletions ────────────────────────────────────────────
    match /pending_deletions/{delId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ─── Week 5: Deletion Failures ────────────────────────────────────────────
    match /deletion_failures/{failId} {
      allow read:   if isAdmin();
      allow write:  if isAdmin();
    }

    // ─── Week 6: Driver Locations (Firestore fallback for RTDB) ──────────────
    match /driver_locations/{driverId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Week 6: Job Tracking ────────────────────────────────────────────────
    match /job_tracking/{jobId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Week 6: Health Check ────────────────────────────────────────────────
    match /_health/{doc} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
  }
}
