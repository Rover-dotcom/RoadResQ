rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Drivers ────────────────────────────────────────────────────────────
    // Week 4: includes discipline fields, compliance fields, vehicleHeightMm, etc.
    match /drivers/{driverId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (isOwner(driverId) || isAdmin());
      allow delete: if isAdmin();
    }

    // ─── Jobs ───────────────────────────────────────────────────────────────
    // Week 4: includes clearanceHeightMm, isRestrictedArea, requiresGatePass, etc.
    match /jobs/{jobId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Quote Requests ─────────────────────────────────────────────────────
    match /quote_requests/{quoteId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Garages ────────────────────────────────────────────────────────────
    match /garages/{garageId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── Garage Requests (Week 4: On-Site Repair Bidding) ───────────────────
    // Created by customer, updated by system + garages, viewed by all signed-in
    match /garage_requests/{requestId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Garage Live Requests (broadcast notifications) ─────────────────────
    // Written by system on job creation, read by garages
    match /garage_live_requests/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ─── Driver Discipline Log (Week 4) ─────────────────────────────────────
    // Append-only by system, readable by admin; drivers can read their own
    match /driver_discipline_log/{logId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        resource.data.driverId == request.auth.uid
      );
      allow create: if isSignedIn(); // System writes via server SDK
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Notifications (future) ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}