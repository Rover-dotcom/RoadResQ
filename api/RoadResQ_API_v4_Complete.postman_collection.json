    {
      "name": "\ud83d\udee1\ufe0f Discipline & Safety",
      "description": "Driver discipline, compliance, safety checklists, and priority queue.",
      "item": [
        {
          "name": "Apply No-Show Fee (Customer)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/no-show",
            "body": {
              "mode": "raw",
              "raw": "{\"jobId\":\"{{jobId}}\",\"customerId\":\"{{userId}}\",\"driverId\":\"{{driverId}}\"}"
            },
            "description": "Charges QR 50 (5000 halala) when customer does not respond within 10 minutes of driver arrival."
          }
        },
        {
          "name": "Issue Late Warning (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/warning/{{driverId}}",
            "body": {
              "mode": "raw",
              "raw": "{\"jobId\":\"{{jobId}}\",\"reason\":\"Driver arrived 20 minutes after ETA\"}"
            },
            "description": "Adds 1 warning to driver. At 3 warnings account is auto-suspended."
          }
        },
        {
          "name": "Clear Suspension (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/clear/{{driverId}}",
            "body": {
              "mode": "raw",
              "raw": "{\"adminNote\":\"Driver completed retraining. Suspension cleared.\"}"
            },
            "description": "Resets warning count and lifts suspension."
          }
        },
        {
          "name": "Compliance Check \u2014 All Drivers",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/discipline/compliance-check",
            "description": "Scans all drivers: 30-day notice, 7-day critical, expired = blocked. Run daily via scheduler."
          }
        },
        {
          "name": "Driver Compliance Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/discipline/compliance/{{driverId}}",
            "description": "Returns overallStatus: valid | expiring_soon | expiring_critical | expired. Shows days remaining per document."
          }
        },
        {
          "name": "Priority Queue (Dispatch)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/discipline/priority-queue",
            "description": "All pending jobs scored by urgency + wait time. Highest score dispatched first."
          }
        },
        {
          "name": "Admin Review Queue",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/discipline/admin-review",
            "description": "Custom/Others jobs system could not auto-match. Admin manually assigns driver."
          }
        },
        {
          "name": "Admin Assign Job (Others)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/admin-review/{{jobId}}/assign",
            "body": {
              "mode": "raw",
              "raw": "{\"driverId\":\"{{driverId}}\",\"adminNote\":\"Manually assigned specialized crane truck.\"}"
            },
            "description": "Admin assigns driver to custom job. Marks admin_review_queue resolved."
          }
        },
        {
          "name": "Driver Safety Check (Pre-Trip)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/safety-check/{{jobId}}/driver",
            "body": {
              "mode": "raw",
              "raw": "{\"driverId\":\"{{driverId}}\",\"hookSecured\":true,\"winchLocked\":true,\"safetyLightsOn\":true,\"areaIsSafe\":true,\"vehicleSecured\":true,\"hazardLightsOn\":true,\"properToolsUsed\":true}"
            },
            "description": "All 7 items must be true before job can start. Returns 400 with failedChecks list if any missing."
          }
        },
        {
          "name": "Customer Safety Confirmation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/discipline/safety-check/{{jobId}}/customer",
            "body": {
              "mode": "raw",
              "raw": "{\"userId\":\"{{userId}}\",\"inSafeLocation\":true,\"notStandingBehindVehicle\":true,\"willVerifyIdentity\":true}"
            },
            "description": "3 safety items customer must confirm. Required before job confirmation."
          }
        },
        {
          "name": "Get Safety Checks for Job",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/discipline/safety-check/{{jobId}}",
            "description": "Returns both driver pre-trip and customer confirmation records. bothCompleted flag for UI."
          }
        }
      ]
    },
    {
      "name": "\ud83d\udcb0 Quote Bidding (Industrial)",
      "description": "Multi-driver bidding for industrial/heavy quotes. Customer compares bids and accepts the best.",
      "item": [
        {
          "name": "Submit Bid (Driver/Garage)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/quotes/{{quoteId}}/bid",
            "body": {
              "mode": "raw",
              "raw": "{\"garageId\":\"{{garageId}}\",\"bidderName\":\"Al Rayyan Heavy Transport\",\"price\":85000,\"etaMinutes\":45,\"equipment\":[\"boom_truck\",\"flatbed\"],\"notes\":\"Includes crane operator. Price valid 48hrs.\",\"rating\":4.8,\"vehicleModel\":\"Volvo FH16 Flatbed\"}"
            },
            "description": "price in halala: 85000 = QR 850.00. Multiple bidders allowed. Quote status becomes collecting_bids."
          }
        },
        {
          "name": "View All Bids (Customer)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/quotes/{{quoteId}}/bids",
            "description": "Sorted by price ASC. isBestPrice and isFastestArrival flags highlight top bids. Returns lowestPriceDisplay."
          }
        },
        {
          "name": "Accept Winning Bid (Customer)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/quotes/{{quoteId}}/bids/BID_ID_HERE/accept",
            "description": "Accepts winning bid, rejects all others automatically, creates linked job with bid price and ETA."
          }
        }
      ]
    }
  ]
