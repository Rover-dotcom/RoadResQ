{
  "info": {
    "name": "RoadResQ API v4 \u2014 Complete",
    "description": "RoadResQ logistics platform \u2014 All endpoints. Base URL: https://api-h6acdw3itq-ww.a.run.app\n\nKey flows:\n1. Jobs: Customer creates job \u2192 auto-dispatch \u2192 driver accepts \u2192 status updates\n2. Quotes: Customer submits \u2192 Garage responds with price \u2192 Customer accepts \u2192 Job created\n3. Garage: Customer creates repair request \u2192 Garages bid \u2192 Customer accepts estimate\n4. Drivers: Register \u2192 Approve \u2192 Go Online \u2192 Accept Jobs\n5. Discipline: No-show fees, warnings, safety checklists, compliance\n6. Bidding: Multi-driver bids on industrial quotes, customer picks best",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "4.0.0"
  },
