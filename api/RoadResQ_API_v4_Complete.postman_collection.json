              "path": [
                "api",
                "jobs",
                "available"
              ],
              "query": [
                {
                  "key": "truckType",
                  "value": "standard_tow"
                },
                {
                  "key": "serviceType",
                  "value": "tow"
                }
              ]
            },
            "description": "Returns open jobs that match the driver's truck type. Driver app polls or listens to this."
          }
        },
        {
          "name": "Accept Job",
          "request": {
            "method": "PUT",
            "header": [
              {
