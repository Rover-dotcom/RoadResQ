# Environment variables for RoadResQ Backend
# Copy this file to .env and fill in your values — NEVER commit .env

PORT=3000
NODE_ENV=development

# Firebase Admin SDK — download from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_PATH=./config/serviceAccountKey.json

# Or use individual env vars if deploying without a file:
# FIREBASE_PROJECT_ID=roadresq-bd6b0
# FIREBASE_CLIENT_EMAIL=your-service-account@roadresq-bd6b0.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Maps API Key (Browser Key — used for Distance Matrix, Directions, Geocoding)
# Get from: Google Cloud Console → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your-google-maps-browser-key-here

# Google Maps Platform Keys Reference (Week 8):
# iOS Key:     For Flutter iOS app (set in AppDelegate.swift)
# Android Key: For Flutter Android app (set in AndroidManifest.xml)
# Browser Key: For backend server API calls (set here as GOOGLE_MAPS_API_KEY)
