              "path": ["api", "jobs"],
              "query": [{ "key": "status", "value": "completed" }]
            }
          }
        },
        {
          "name": "All Quotes Report",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/quotes",
            "description": "All quotes across all users and garages."
          }
        },
        {
          "name": "All Garage Requests Report",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/garage-requests",
            "description": "All on-site repair requests."
          }
        },
        {
          "name": "All Drivers Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/drivers?isApproved=false",
              "host": ["{{base_url}}"],
              "path": ["api", "drivers"],
              "query": [{ "key": "isApproved", "value": "false" }]
            },
